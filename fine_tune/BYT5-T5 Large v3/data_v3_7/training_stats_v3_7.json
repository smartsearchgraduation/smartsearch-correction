    "fixes_applied_v36": [
      "+200k real-world English phrase identity (Tatoeba-style OR curated) -> model learns 'correct English stays unchanged'",
      "+25k brand+model identity (Apple, Samsung, iPhone 15 Pro Max, RTX 4090, MacBook Pro M3, Nike Air Force 1, Sony WH-1000XM5...) -> preserve brand capitalization & punctuation",
      "+1k compound-word identity (airpods, macbook, iphone, smartwatch, bookshelf, ...) -> do NOT split compounds that are conventionally solid",
      "+0.7k case-sensitive identity (iPhone, AirPods Pro, PlayStation 5, Wi-Fi, L'Or\u00e9al...) -> preserve case & punctuation",
      "+77k partial-typo (brand intact, category/adjective typo'd) -> typo adjectives/categories, keep brands exact",
      "+13k generic English identity (greetings, small-talk, quotes) -> don't 'correct' already-correct English",
      "+16 split-to-compound counter-example (air pods -> airpods, mac book -> macbook, ...) -> keep real compounds together"
    ],
    "fixes_applied_v35": [
      "+300k English template expansion (price/ship/loc/quality/review/intent/use)",
      "+120k marketplace patterns (Amazon/Walmart/Target/eBay/BestBuy/Costco/etc)",
